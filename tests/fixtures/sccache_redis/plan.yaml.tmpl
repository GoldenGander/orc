failure_policy: fail_fast
max_parallel: 1
total_cpu_slots: 4
total_memory_slots: 4
resource_network: {network}

resources:
  - id: redis
    kind: cache
    lifetime: managed
    driver: docker_container
    image: redis:7-alpine
    aliases: [redis]
    command:
      - redis-server
      - --bind
      - 0.0.0.0
      - --protected-mode
      - "no"
      - --port
      - "6379"
      - --dir
      - /var/lib/redis
      - --dbfilename
      - dump.rdb
      - --save
      - "1 1"
      - --appendonly
      - "no"
    volumes:
      - host_path: "{redis_host_path}"
        container_path: /var/lib/redis

jobs:
  - id: consumer
    image: {image_tag}
    command: ["bash", "/src/consumer.sh"]
    cpu_slots: 1
    memory_slots: 1
    depends_on: []
    artifacts:
      - source_glob: "*.json"
        destination_subdir: combined
